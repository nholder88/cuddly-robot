<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="AI Agent Workflows Pack"
    Manufacturer="nholder88"
    Version="1.0.0"
    UpgradeCode="7A51A879-B5E2-4139-9D0C-34C03EF70E6B"
    Scope="perUser"
    InstallerVersion="500">

    <MajorUpgrade DowngradeErrorMessage="A newer AI Agent Workflows Pack is already installed." />
    <MediaTemplate />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="InstallRootDir" Name="ai-agent-workflows-pack">
        <Directory Id="PayloadRootDir" Name="payload" />
      </Directory>
    </StandardDirectory>

    <Feature Id="MainFeature" Title="AI Agent Workflows Pack" Level="1">
      <ComponentGroupRef Id="PayloadFiles" />
    </Feature>

    <InstallExecuteSequence>
      <Custom Action="RunSetup" After="InstallFinalize" Condition="NOT REMOVE" />
    </InstallExecuteSequence>

    <CustomAction
      Id="RunSetup"
      Directory="InstallRootDir"
      ExeCommand="powershell.exe -NoProfile -ExecutionPolicy Bypass -File &quot;[InstallRootDir]payload\installer\Setup.ps1&quot; -InstallRoot &quot;[InstallRootDir]&quot; -SourceRepoPath &quot;[InstallRootDir]payload&quot;"
      Execute="immediate"
      Return="check"
      Impersonate="yes" />

    <ComponentGroup Id="PayloadFiles" Directory="PayloadRootDir">
      <Files Include="..\..\**" Exclude="..\..\.git\**;..\..\node_modules\**;..\..\dist\**;..\..\build\**;..\..\installer\msi\out\**;..\..\agent-progress\**;..\..\**\agent-progress\**" />
    </ComponentGroup>
  </Package>
</Wix>

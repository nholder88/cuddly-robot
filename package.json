{
  "name": "@nholder88/ai-agent-workflows-tools",
  "version": "1.0.0",
  "description": "Installable pack of AI agent definitions, stack templates, and skills for VS Code, Cursor, and Claude Code — with a multi-IDE CLI installer.",
  "keywords": [
    "ai",
    "agents",
    "vscode",
    "cursor",
    "github-copilot",
    "prompts",
    "templates",
    "skills",
    "cli"
  ],
  "author": "Nigel Holder <nholder88@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nholder88/ai-agent-workflows.git"
  },
  "bugs": {
    "url": "https://github.com/nholder88/ai-agent-workflows/issues"
  },
  "homepage": "https://github.com/nholder88/ai-agent-workflows#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "restricted",
    "provenance": true
  },
  "type": "module",
  "bin": {
    "ai-agent-pack-install": "./bin/pack-install.mjs"
  },
  "files": [
    "agents",
    "templates",
    "skills",
    "cli",
    "bin"
  ],
  "scripts": {
    "templates:validate-parity": "node --import tsx templates/tools/validate-parity.ts --root .",
    "templates:test-parity": "node --import tsx --test templates/tools/validate-parity.test.ts",
    "pack:install": "node --import tsx cli/pack-install.ts",
    "pack:test": "node --import tsx --test cli/lib/*.test.ts",
    "prepublishOnly": "npm run pack:test"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "ajv": "^8.17.1",
    "tsx": "^4.20.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  }
}

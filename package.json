{
  "name": "ai-agent-workflows-tools",
  "version": "1.0.0",
  "description": "VS Code and Cursor agent pack with templates, skills library, parity tooling, and a multi-IDE pack-install CLI.",
  "keywords": [
    "ai",
    "agents",
    "vscode",
    "cursor",
    "github-copilot",
    "prompts",
    "templates",
    "skills",
    "cli"
  ],
  "author": "Nigel <nholder88@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nholder88/cuddly-robot.git"
  },
  "bugs": {
    "url": "https://github.com/nholder88/cuddly-robot/issues"
  },
  "homepage": "https://github.com/nholder88/cuddly-robot#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "bin": {
    "ai-agent-pack-install": "./bin/pack-install.mjs"
  },
  "files": [
    "agents",
    "templates",
    "skills",
    "cli",
    "bin"
  ],
  "scripts": {
    "templates:validate-parity": "node --import tsx templates/tools/validate-parity.ts --root .",
    "templates:test-parity": "node --import tsx --test templates/tools/validate-parity.test.ts",
    "pack:install": "node --import tsx cli/pack-install.ts",
    "pack:test": "node --import tsx --test cli/lib/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "ajv": "^8.17.1",
    "yaml": "^2.8.1"
  }
}

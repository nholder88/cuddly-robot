{
  "version": 1,
  "tools": [
    {
      "id": "vscode",
      "label": "VS Code (GitHub Copilot agents / prompts)",
      "adapterId": "vscode-agent",
      "agentsRootByPlatform": {
        "win32": "{APPDATA}/Code/User/prompts",
        "darwin": "{HOME}/Library/Application Support/Code/User/prompts",
        "linux": "{HOME}/.config/Code/User/prompts"
      }
    },
    {
      "id": "cursor",
      "label": "Cursor",
      "adapterId": "cursor-agent",
      "agentsRootByPlatform": {
        "win32": "{APPDATA}/Cursor/User/prompts",
        "darwin": "{HOME}/Library/Application Support/Cursor/User/prompts",
        "linux": "{HOME}/.config/Cursor/User/prompts"
      }
    }
  ]
}
